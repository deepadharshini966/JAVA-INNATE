public class StringLength {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Length: " + str.length());
    }
}
public class StringCharAt {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Character at index 4: " + str.charAt(4));
    }
}
public class StringSubstring {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Substring (0,5): " + str.substring(0, 5));
    }
}
public class StringEquals {
    public static void main(String[] args) {
        String str1 = "Hello World";
        String str2 = "hello world";

        System.out.println("Equals: " + str1.equals(str2));
        System.out.println("Equals Ignore Case: " + str1.equalsIgnoreCase(str2));
    }
}
public class StringCompare {
    public static void main(String[] args) {
        String str1 = "Hello";
        String str2 = "World";

        System.out.println("Compare result: " + str1.compareTo(str2));
    }
}
public class StringConcat {
    public static void main(String[] args) {
        String str1 = "Hello";
        String str2 = "World";
        System.out.println("Concatenated: " + str1.concat(" " + str2));
    }
}
public class StringCase {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Uppercase: " + str.toUpperCase());
        System.out.println("Lowercase: " + str.toLowerCase());
    }
}
public class StringTrim {
    public static void main(String[] args) {
        String str = "   Java Programming   ";
        System.out.println("Before trim: '" + str + "'");
        System.out.println("After trim: '" + str.trim() + "'");
    }
}
public class StringSplit {
    public static void main(String[] args) {
        String sentence = "Java is fun to learn";
        String[] words = sentence.split(" ");

        System.out.println("Split words:");
        for (int i = 0; i < words.length; i++) {
            System.out.println(words[i]);
        }
    }
}
public class StringIndexOf {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Index of 'World': " + str.indexOf("World"));
    }
}
public class ToCharArrayExample {
    public static void main(String[] args) {
        String str = "Hello";
        char[] chars = str.toCharArray();

        System.out.println("Characters:");
        for (int i = 0; i < chars.length; i++) {
            System.out.println(chars[i]);
        }
    }
}
public class StartsWithExample {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Starts with 'Hello'? " + str.startsWith("Hello"));
    }
}
public class EndsWithExample {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Ends with 'World'? " + str.endsWith("World"));
    }
}
public class ReplaceFirstExample {
    public static void main(String[] args) {
        String str = "Java Java Java";
        System.out.println("After replaceFirst: " + str.replaceFirst("Java", "Python"));
    }
}
public class ReplaceAllExample {
    public static void main(String[] args) {
        String str = "Java Java Java";
        System.out.println("After replaceAll: " + str.replaceAll("Java", "Python"));
    }
}
public class ContainsExample {
    public static void main(String[] args) {
        String str = "Hello World";
        System.out.println("Contains 'World'? " + str.contains("World"));
    }
}
